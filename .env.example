# Easy-WoL environment example
# Copy this file to .env and adjust the values before deployment.

# HTTP port used inside the container. With network_mode: host this is also the host port.
PORT=8080

# Required. Change this before running Easy-WoL.
ADMIN_PASSWORD=change-this-password

# SQLite database location inside the container.
DB_PATH=/app/data/easy-wol.sqlite

# Directory inside the container that contains private SSH keys for relay sites.
SSH_KEY_DIR=/app/ssh
